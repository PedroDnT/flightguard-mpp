# ============================================================
# FlightGuard MPP — Environment Variables
# Copy to .env and fill in values before running
# ============================================================

# --- TEMPO NETWORK ---
# Pool wallet: this is the "insurer" wallet.
# Use the same wallet for both variables:
# - POOL_PRIVATE_KEY = private key
# - POOL_ADDRESS     = public address derived from that same private key
POOL_PRIVATE_KEY=0x...your_private_key_here...
POOL_ADDRESS=0x...public_address_of_the_same_wallet...

# Tempo testnet (default) — switch to mainnet for production
TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
CHAIN_ID=42431

# --- ALCHEMY (optional, recommended for production) ---
# Get a free API key at https://dashboard.alchemy.com/chains/tempo
# When set, TEMPO_RPC_URL is ignored and Alchemy's enterprise RPC is used:
#   Testnet (42431): https://tempo-moderato.g.alchemy.com/v2/<key>
#   Mainnet (4217):  https://tempo-mainnet.g.alchemy.com/v2/<key>
# Also enables WebSocket transport for lower-latency tx monitoring.
ALCHEMY_API_KEY=

# MPP service URL for Alchemy Prices + Portfolio APIs (paid with pathUSD).
# Discover the endpoint: tempo wallet services --search alchemy
# When set, FlightGuard pays Alchemy per-call via MPP session (5 pathUSD deposit).
ALCHEMY_SERVICE_URL=

# pathUSD stablecoin — do not change for testnet
PATHUSD_ADDRESS=0x20c0000000000000000000000000000000000000

# --- FLIGHT DATA ---
# Get a free key at https://rapidapi.com/aedbx-aedbx/api/aerodatabox
RAPIDAPI_KEY=your_rapidapi_key_here

# --- SERVER ---
PORT=3000

# --- INSURANCE PARAMETERS ---
# Premium amount in USD (stablecoin units)
PREMIUM_AMOUNT=1.00

# Payout = premium * this multiplier
PAYOUT_MULTIPLIER=5

# Flight must be delayed by this many minutes to trigger payout
DELAY_THRESHOLD_MIN=60

# How often the checker polls flights (milliseconds)
# 300000 = 5 minutes
CHECK_INTERVAL_MS=300000

# --- PERSISTENCE ---
# Path to JSON file for storing policies across restarts
STORE_PATH=policies.json

# --- ADMIN ---
# Use a long, random, unique password for admin panel access
# In production, store this secret in a secrets manager rather than sharing or reusing it
ADMIN_PASSWORD=replace_with_a_long_random_unique_password

# Path to audit log JSON file
AUDIT_LOG_PATH=audit.json
