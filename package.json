{
  "name": "flightguard-mpp",
  "version": "0.1.0",
  "description": "Parametric flight delay insurance on Tempo using MPP micropayments",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:all": "bash scripts/start-all.sh",
    "checker": "tsx index.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "compile": "hardhat compile",
    "test:contracts": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.js --network tempo-testnet",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network tempo",
    "faucet": "node scripts/faucet.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.0.0",
    "hono": "^4.12.14",
    "mppx": "^0.4.11",
    "next": "^16.2.4",
    "node-fetch": "^3.0.0",
    "postcss": "^8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@types/node": "^20.0.0",
    "hardhat": "^3.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.1"
  }
}
