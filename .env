# FlightGuard MPP local environment
# Replace these placeholders before running the app.

# Pool wallet: this is the insurer wallet that receives premiums and sends payouts
POOL_PRIVATE_KEY=0x...your_private_key_here...
POOL_ADDRESS=0x...public_address_derived_from_private_key_above...

# Tempo testnet defaults
TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
CHAIN_ID=42431
PATHUSD_ADDRESS=0x20c0000000000000000000000000000000000000

# Flight data
RAPIDAPI_KEY=your_rapidapi_key_here

# Server
PORT=3000

# Insurance parameters
PREMIUM_AMOUNT=1.00
PAYOUT_MULTIPLIER=5
DELAY_THRESHOLD_MIN=60
CHECK_INTERVAL_MS=300000

# Persistence
STORE_PATH=policies.json
